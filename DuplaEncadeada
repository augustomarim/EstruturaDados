#include <stdio.h>
#include <stdlib.h>

typedef struct cel{
    int conteudo;
    struct cel *seg;
    struct cel *ant;
}cel;

typedef struct cel* ListaDup;

ListaDup* criar_Lista(){
    ListaDup *li = (ListaDup*) malloc (sizeof(ListaDup));
    if(li != NULL){
        *li = NULL;
    }
    return li;
}

int insere_lista_fim(ListaDup *lista, int x){
    if(lista == NULL){
        return 0;
    }
    cel* aux = (cel*) malloc (sizeof(cel));
    if(aux == NULL) {
        return 0;
    }
    aux->conteudo = x; 
    aux->seg = NULL;
    if((*lista) == NULL){
        *lista = aux;
    }
    else{
        cel *temp;
        temp = *lista;
        while(temp->seg !=NULL){
            temp = temp->seg;
        }
        temp->seg = aux;
        aux->ant = temp;
    }
    return 1;
}

int insere_lista_comeco(ListaDup *lista, int x){
    if(lista == NULL){
        return 0;
    }
    cel* aux = (cel*) malloc (sizeof(cel));
    if(aux == NULL) {
        return 0;
    }
    
    aux->conteudo = x; 
    aux->seg = *lista;
    aux->ant = NULL;
    *lista = aux;
    return 1;
}


void imprimir_lista(ListaDup* lista){
    if(lista == NULL){
       printf("\nLista não existe\n");
    }else{
            if(*lista == NULL){
            printf("\nLista vazia\n");
        }
        cel* temp;
        temp = *lista;
        while(temp !=NULL){
            printf("%d | ", temp->conteudo);
            temp = temp->seg;
        }
    }
}



int main()
{
    printf("INICIO\n");
    ListaDup *lst;
    lst = criar_Lista();
    
    insere_lista_fim(lst,1);
    insere_lista_fim(lst,2);
    insere_lista_fim(lst,4);
    insere_lista_fim(lst,8);
    insere_lista_fim(lst,3);
    insere_lista_comeco(lst,9);
    
    
    imprimir_lista(lst);

    return 0;
}
