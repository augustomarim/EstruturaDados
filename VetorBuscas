void BubbleSort(int *x, int n){
    int i, continua, aux, fim = n;
    do{
        continua = 0;
        for(i = 0; i<fim-1; i++){
            if(x[i] > x[i+1]){
                aux = x[i];
                x[i] = x[i+1];
                x[i+1] = aux;
                continua = 1;
                ImprimeVetor(x,n);
            }
        }
        fim --;
    }while(continua);
}

void InsertionSort(int *x, int n){
    int i, j, aux;
    for(i = 1; i < n; i++){
        aux = x[i];
        for(j = i; ((j > 0) && (aux < x[j-1])); j--){
            x[j] = x[j-1];
        }
        x[j] = aux;
        ImprimeVetor(x, n);
    }
        
}

